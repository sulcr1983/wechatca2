{
  "name": "Monocle·生活",
  "description": "Monocle 杂志风 #2a6e3f + 橄榄绿金配色，精致生活美学，适合城市文化、品质生活、设计建筑内容",
  "colors": {
    "primary": "#2a5e38",
    "accent": "#b8a04a",
    "background": "#fdfdfa",
    "blockquote_bg": "#f7f6f0",
    "code_bg": "#f5f4ee",
    "hr_color": "#b8a04a",
    "footnote_bg": "#fdfdfa"
  },
  "styles": {
    "wrapper": { "background_color": "#fdfdfa", "padding": "16px" },
    "h1": { "font_size": "27px", "font_weight": "700", "color": "#2a5e38", "line_height": "1.25", "margin_top": "0", "margin_bottom": "36px", "text_align": "center", "letter_spacing": "0.1em", "font_family": "Georgia, 'Times New Roman', 'STSong', serif", "padding": "0", "border_bottom": "2px solid #b8a04a", "padding_bottom": "16px" },
    "h2": { "font_size": "22px", "font_weight": "600", "color": "#2a5e38", "line_height": "1.4", "font_family": "Georgia, 'Times New Roman', serif", "margin_top": "36px", "margin_bottom": "16px", "text_align": "center", "letter_spacing": "0.06em", "padding": "0" },
    "h3": { "font_size": "19px", "font_weight": "600", "color": "#b8a04a", "line_height": "1.4", "margin_top": "26px", "margin_bottom": "12px", "padding": "0", "text_align": "center", "letter_spacing": "0.05em" },
    "p": { "font_size": "15px", "color": "#3a4038", "line_height": "1.85", "margin_top": "0", "margin_bottom": "22px", "letter_spacing": "0.02em", "text_align": "left" },
    "blockquote": { "border_left": "3px solid #b8a04a", "background": "#f7f6f0", "padding": "20px 24px", "border_radius": "4px", "margin_top": "18px", "margin_bottom": "24px", "font_size": "15px", "color": "#5a5a4a", "line_height": "1.85", "font_style": "italic" },
    "blockquote_p": { "font_size": "15px", "color": "#5a5a4a", "line_height": "1.85", "margin_bottom": "0", "font_style": "italic" },
    "strong": { "font_weight": "700", "color": "#2a5e38" },
    "em": { "font_style": "italic", "color": "#b8a04a" },
    "a": { "color": "#2a5e38", "text_decoration": "none", "border_bottom": "1px solid #b8a04a" },
