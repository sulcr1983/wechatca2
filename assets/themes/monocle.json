    "img_wrapper": { "background": "#ffffff", "border_radius": "6px", "padding": "4px", "margin_top": "18px", "margin_bottom": "18px" },
    "hr": { "margin_top": "42px", "margin_bottom": "42px", "height": "1px", "background": "linear-gradient(to right, transparent, #b8a04a, #bbb, #b8a04a, transparent)", "border": "none", "width": "100%" },
    "code": { "background": "#f5f4ee", "padding": "2px 8px", "border_radius": "3px", "font_size": "90%", "color": "#2a5e38", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "code_block": { "background": "#f5f4ee", "border_radius": "4px", "margin_top": "18px", "margin_bottom": "18px", "overflow": "hidden", "border": "1px solid #e5e2d8" },
    "code_header": { "display": "flex", "align_items": "center", "height": "30px", "padding": "0 12px", "background": "#e8e4d8" },
    "pre": { "background": "#f5f4ee", "color": "#3a4038", "padding": "16px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.5", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#3a4038", "font_size": "13px", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "18px", "margin_bottom": "18px", "font_size": "14px", "border_spacing": "0", "border_radius": "4px", "overflow": "hidden", "box_shadow": "0 2px 6px rgba(0,0,0,0.04)" },
    "th": { "background": "#2a5e38", "padding": "12px 16px", "text_align": "left", "font_weight": "600", "color": "#fdfdfa", "border_bottom": "2px solid #b8a04a", "font_size": "12px", "letter_spacing": "0.04em" },
    "td": { "padding": "12px 16px", "font_size": "14px", "line_height": "1.7", "background": "#ffffff", "color": "#3a4038", "border_bottom": "1px solid #e5e2d8" },
    "list_item_bullet": { "color": "#b8a04a", "margin_right": "10px", "font_weight": "bold" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "22px", "height": "22px", "min_width": "22px", "background": "rgba(184,160,74,0.12)", "color": "#2a5e38", "border_radius": "50%", "font_size": "12px", "font_weight": "600", "margin_right": "10px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#3a4038", "line_height": "1.85", "letter_spacing": "0.02em" },
    "list_wrapper": { "margin_top": "16px", "margin_bottom": "16px" },
    "list_item_row": { "display": "flex", "margin_bottom": "7px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "36px", "padding_top": "16px", "border_top": "1px solid #e5e2d8" },
    "footnote_title": { "font_size": "12px", "font_weight": "600", "color": "#999988", "margin_bottom": "10px", "letter_spacing": "0.05em" },
    "footnote_item": { "font_size": "11px", "color": "#999988", "margin_bottom": "5px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "10px", "color": "#b8a04a", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "#f7f6f0", "border_left": "3px solid #b8a04a", "padding": "16px 20px", "margin_top": "18px", "margin_bottom": "18px", "border_radius": "4px" },
    "callout_title": { "font_weight": "600", "color": "#2a5e38", "margin_bottom": "8px", "font_size": "15px", "letter_spacing": "0.04em" },
    "callout_content": { "font_size": "14px", "color": "#5a5a4a", "line_height": "1.85", "letter_spacing": "0.02em" },
    "h4": { "font_size": "17px", "font_weight": "600", "color": "#2a5e38", "padding": "0", "margin_top": "24px", "margin_bottom": "10px", "line_height": "1.4", "font_family": "Georgia, serif" },
    "h5": { "font_size": "16px", "font_weight": "500", "color": "#5a6a50", "padding": "0", "margin_top": "20px", "margin_bottom": "8px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#778870", "padding": "0", "margin_top": "14px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}