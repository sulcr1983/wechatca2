{
  "name": "秋叶·橙",
  "description": "温暖秋叶 #e87830 + 奶油底色 #fffbf6，丰收暖意自然风格，适合节气文章、美食分享、温馨故事",
  "colors": {
    "primary": "#d06828",
    "accent": "#e87830",
    "background": "#fffbf6",
    "blockquote_bg": "rgba(232,120,48,0.04)",
    "code_bg": "#fff8f0",
    "hr_color": "#e87830",
    "footnote_bg": "#fffbf6"
  },
  "styles": {
    "wrapper": { "background_color": "#fffbf6", "padding": "16px" },
    "h1": { "font_size": "26px", "font_weight": "700", "color": "#ffffff", "background": "linear-gradient(135deg, #e87830, #d06828)", "padding": "14px 22px", "border_radius": "12px", "margin_top": "0", "margin_bottom": "30px", "line_height": "1.4", "letter_spacing": "0.04em", "box_shadow": "0 4px 12px rgba(232,120,48,0.2)" },
    "h2": { "font_size": "21px", "font_weight": "600", "color": "#d06828", "padding_left": "12px", "border_left": "3px solid #e87830", "margin_top": "30px", "margin_bottom": "16px", "line_height": "1.4" },
    "h3": { "font_size": "18px", "font_weight": "600", "color": "#d06828", "padding": "4px 0", "border_bottom": "2px dotted rgba(232,120,48,0.25)", "margin_top": "24px", "margin_bottom": "12px", "line_height": "1.4" },
    "p": { "font_size": "15px", "color": "#4a3830", "line_height": "1.85", "margin_top": "0", "margin_bottom": "20px", "letter_spacing": "0.03em", "text_align": "left" },
    "blockquote": { "border_left": "3px solid #e87830", "background": "rgba(232,120,48,0.04)", "padding": "16px 20px", "border_radius": "8px", "margin_top": "16px", "margin_bottom": "22px", "font_size": "14px", "color": "#6a5240", "line_height": "1.8" },
    "blockquote_p": { "font_size": "14px", "color": "#6a5240", "line_height": "1.8", "margin_bottom": "0" },
    "strong": { "font_weight": "700", "color": "#d06828" },
    "em": { "font_style": "italic", "color": "#b85820" },
    "a": { "color": "#e87830", "text_decoration": "none" },
    "img": { "max_width": "100%", "border_radius": "10px", "display": "block", "box_shadow": "0 4px 12px rgba(232,120,48,0.1)" },
    "img_wrapper": { "background": "#ffffff", "border_radius": "12px", "padding": "5px", "margin_top": "16px", "margin_bottom": "16px" },
    "hr": { "margin_top": "34px", "margin_bottom": "34px", "height": "2px", "background": "linear-gradient(to right, transparent, rgba(232,120,48,0.3), rgba(232,120,48,0.3), transparent)", "border": "none", "width": "70%" },
    "code": { "background": "#fff8f0", "padding": "2px 8px", "border_radius": "6px", "font_size": "90%", "color": "#d06828", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "code_block": { "background": "#fff8f0", "border_radius": "8px", "margin_top": "18px", "margin_bottom": "18px", "overflow": "hidden", "border": "1px solid rgba(232,120,48,0.12)" },
    "code_header": { "display": "flex", "align_items": "center", "height": "30px", "padding": "0 12px", "background": "rgba(232,120,48,0.08)" },
    "pre": { "background": "#fff8f0", "color": "#4a3830", "padding": "14px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.5", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#4a3830", "font_size": "13px", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "18px", "margin_bottom": "18px", "font_size": "14px", "border_spacing": "0", "border_radius": "10px", "overflow": "hidden", "box_shadow": "0 2px 8px rgba(232,120,48,0.06)" },
    "th": { "background": "rgba(232,120,48,0.12)", "padding": "12px 16px", "text_align": "left", "font_weight": "600", "color": "#d06828", "border_bottom": "2px solid rgba(232,120,48,0.2)", "font_size": "13px" },
    "td": { "padding": "12px 16px", "font_size": "14px", "line_height": "1.65", "background": "#ffffff", "color": "#4a3830", "border_bottom": "1px solid rgba(232,120,48,0.06)" },
    "list_item_bullet": { "color": "#e87830", "margin_right": "8px", "font_weight": "bold" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "22px", "height": "22px", "min_width": "22px", "background": "rgba(232,120,48,0.12)", "color": "#d06828", "border_radius": "50%", "font_size": "12px", "font_weight": "600", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#4a3830", "line_height": "1.85", "letter_spacing": "0.03em" },
    "list_wrapper": { "margin_top": "16px", "margin_bottom": "16px" },
    "list_item_row": { "display": "flex", "margin_bottom": "6px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "32px", "padding_top": "16px", "border_top": "1px dashed rgba(232,120,48,0.2)" },
    "footnote_title": { "font_size": "12px", "font_weight": "500", "color": "#aa9990", "margin_bottom": "10px" },
    "footnote_item": { "font_size": "11px", "color": "#aa9990", "margin_bottom": "5px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "10px", "color": "#e87830", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "rgba(232,120,48,0.05)", "border_left": "3px solid #e87830", "padding": "16px 20px", "margin_top": "16px", "margin_bottom": "16px", "border_radius": "8px" },
    "callout_title": { "font_weight": "600", "color": "#d06828", "margin_bottom": "8px", "font_size": "15px" },
    "callout_content": { "font_size": "14px", "color": "#6a5240", "line_height": "1.8", "letter_spacing": "0.03em" },
    "h4": { "font_size": "17px", "font_weight": "600", "color": "#d06828", "padding": "0", "margin_top": "22px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "500", "color": "#887060", "padding": "0", "margin_top": "18px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#aa8870", "padding": "0", "margin_top": "14px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}