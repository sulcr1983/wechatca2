{
  "name": "高管·蓝",
  "description": "深蓝 #0d2137 + 金属金 #c8a44e，权威正式的商务风格，适合企业公告、行业分析、专业报告",
  "colors": {
    "primary": "#0d2137",
    "accent": "#c8a44e",
    "background": "#ffffff",
    "blockquote_bg": "#f5f6f8",
    "code_bg": "#f2f3f5",
    "hr_color": "#c8a44e",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#ffffff",
      "background_color": "#0d2137",
      "padding": "16px 24px",
      "border_radius": "4px",
      "border_left": "4px solid #c8a44e",
      "margin_top": "0",
      "margin_bottom": "32px",
      "line_height": "1.4",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, 'Times New Roman', serif"
    },
    "h2": {
      "font_size": "21px",
      "font_weight": "600",
      "color": "#0d2137",
      "padding": "0 0 10px 0",
      "border_bottom": "2px solid #c8a44e",
      "margin_top": "32px",
      "margin_bottom": "18px",
      "line_height": "1.4",
      "letter_spacing": "0.03em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#0d2137",
      "padding_left": "12px",
      "border_left": "3px solid #c8a44e",
      "margin_top": "26px",
      "margin_bottom": "14px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#2a3040",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "blockquote": {
      "border_left": "3px solid #c8a44e",
      "background": "#f5f6f8",
      "padding": "16px 22px",
      "border_radius": "0 4px 4px 0",
      "margin_top": "16px",
      "margin_bottom": "22px",
      "font_size": "14px",
      "color": "#555a66",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#555a66",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#0d2137"
    },
    "em": {
      "font_style": "italic",
      "color": "#445566"
    },
    "a": {
      "color": "#0d2137",
      "text_decoration": "none",
      "border_bottom": "1px solid #c8a44e"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "3px",
      "display": "block",
      "box_shadow": "0 2px 10px rgba(0,0,0,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "4px",
      "padding": "3px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "2px",
      "background": "linear-gradient(to right, transparent, #c8a44e, transparent)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "#f2f3f5",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "90%",
      "color": "#0d2137",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#f5f6f8",
      "border_radius": "4px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "border": "1px solid #e5e7ea"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "#e5e7ea"
    },
    "pre": {
      "background": "#f5f6f8",
      "color": "#2a3040",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#2a3040",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "4px",
      "overflow": "hidden",
      "border": "1px solid #e5e7ea"
    },
    "th": {
      "background": "#0d2137",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#ffffff",
      "border_bottom": "2px solid #c8a44e",
      "font_size": "12px",
      "letter_spacing": "0.05em"
    },
    "td": {
      "padding": "12px 16px",
      "font_size": "14px",
      "line_height": "1.65",
      "background": "#ffffff",
      "color": "#2a3040",
      "border_bottom": "1px solid #e5e7ea"
    },
    "list_item_bullet": {
      "color": "#c8a44e",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "#0d2137",
      "color": "#ffffff",
      "border_radius": "3px",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2a3040",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #e5e7ea"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#999999",
      "margin_bottom": "10px",
      "letter_spacing": "0.04em"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#999999",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#c8a44e",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f5f6f8",
      "border_left": "3px solid #0d2137",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 4px 4px 0"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#0d2137",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#555a66",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "#0d2137",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#445566",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#667788",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    }
  }
}