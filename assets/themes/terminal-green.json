{
  "name": "终端·绿",
  "description": "经典终端 #0c0c0c + 复古绿 #33ff33，CRT 显示器风格，适合后端开发、命令行教程、极客内容",
  "colors": {
    "primary": "#33ff33",
    "accent": "#33ff33",
    "background": "#0c0c0c",
    "blockquote_bg": "rgba(51,255,51,0.04)",
    "code_bg": "#141414",
    "hr_color": "#33ff33",
    "footnote_bg": "#0c0c0c"
  },
  "styles": {
    "wrapper": {
      "background_color": "#0c0c0c",
      "padding": "16px"
    },
    "h1": {
      "font_size": "24px",
      "font_weight": "700",
      "color": "#33ff33",
      "line_height": "1.3",
      "margin_top": "0",
      "margin_bottom": "32px",
      "letter_spacing": "0.04em",
      "padding": "10px 16px",
      "border": "1px solid #33ff33",
      "border_radius": "2px",
      "font_family": "'JetBrains Mono', Consolas, monospace",
      "text_align": "left"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#33ff33",
      "line_height": "1.3",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "padding_left": "10px",
      "border_left": "3px solid #33ff33",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#28dd28",
      "line_height": "1.4",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "padding": "0",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "p": {
      "font_size": "15px",
      "color": "#c8ccc8",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "blockquote": {
      "border_left": "3px solid #33ff33",
      "background": "rgba(51,255,51,0.04)",
      "padding": "14px 18px",
      "border_radius": "2px",
      "margin_top": "14px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "color": "#99aa99",
      "line_height": "1.7"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#99aa99",
      "line_height": "1.7",
      "margin_bottom": "0",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "strong": {
      "font_weight": "700",
      "color": "#33ff33"
    },
    "em": {
      "font_style": "italic",
      "color": "#88cc88"
    },
    "a": {
      "color": "#33ff33",
      "text_decoration": "underline"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "2px",
      "display": "block",
      "border": "1px solid rgba(51,255,51,0.1)"
    },
    "img_wrapper": {
      "background": "#0c0c0c",
      "border_radius": "2px",
      "padding": "2px",
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "hr": {
      "margin_top": "28px",
      "margin_bottom": "28px",
      "height": "1px",
      "background": "linear-gradient(to right, transparent, #33ff33, transparent)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "rgba(51,255,51,0.1)",
      "padding": "3px 8px",
      "border_radius": "2px",
      "font_size": "90%",
      "color": "#33ff33",
      "font_family": "'Courier New', Menlo, Monaco, monospace"
    },
    "code_block": {
      "background": "#141414",
      "border_radius": "2px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "border": "1px solid rgba(51,255,51,0.15)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "30px",
      "padding": "0 10px",
      "background": "rgba(51,255,51,0.05)"
    },
    "pre": {
      "background": "#141414",
      "color": "#33ff33",
      "padding": "14px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.45",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#33ff33",
      "font_size": "13px",
      "font_family": "'Courier New', Menlo, Monaco, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border_spacing": "0",
      "overflow": "hidden",
      "border": "1px solid rgba(51,255,51,0.12)"
    },
    "th": {
      "background": "rgba(51,255,51,0.1)",
      "padding": "10px 14px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#33ff33",
      "border_bottom": "1px solid rgba(51,255,51,0.18)",
      "font_size": "12px",
      "font_family": "'Courier New', monospace"
    },
    "td": {
      "padding": "10px 14px",
      "font_size": "13px",
      "line_height": "1.6",
      "background": "#0c0c0c",
      "color": "#c8ccc8",
      "border_bottom": "1px solid rgba(255,255,255,0.03)"
    },
    "list_item_bullet": {
      "color": "#33ff33",
      "margin_right": "8px",
      "font_weight": "bold",
      "content": ">"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "20px",
      "height": "20px",
      "min_width": "20px",
      "background": "rgba(51,255,51,0.12)",
      "color": "#33ff33",
      "border_radius": "2px",
      "font_size": "11px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px",
      "font_family": "'Courier New', monospace"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#c8ccc8",
      "line_height": "1.75",
      "letter_spacing": "0.02em",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "5px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px dashed rgba(51,255,51,0.12)"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#557755",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#557755",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#33ff33",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(51,255,51,0.05)",
      "border_left": "3px solid #33ff33",
      "padding": "14px 18px",
      "margin_top": "14px",
      "margin_bottom": "14px",
      "border_radius": "2px"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#33ff33",
      "margin_bottom": "6px",
      "font_size": "14px",
      "font_family": "'Courier New', monospace"
    },
    "callout_content": {
      "font_size": "13px",
      "color": "#99aa99",
      "line_height": "1.75",
      "letter_spacing": "0.02em",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "600",
      "color": "#28dd28",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "500",
      "color": "#77aa77",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#668866",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, 'PingFang SC', monospace"
    }
  }
}