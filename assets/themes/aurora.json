{
  "name": "极光·渐变",
  "description": "紫绿极光渐变 #7c3aed + #10b981，梦幻流动色彩，适合创意设计、艺术展览、品牌视觉内容",
  "colors": {
    "primary": "#7c3aed",
    "accent": "#10b981",
    "background": "#ffffff",
    "blockquote_bg": "rgba(124,58,237,0.03)",
    "code_bg": "#f8f6ff",
    "hr_color": "#7c3aed",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "#ffffff",
      "background": "linear-gradient(135deg, #7c3aed 0%, #6366f1 30%, #10b981 70%, #059669 100%)",
      "padding": "18px 24px",
      "border_radius": "14px",
      "margin_top": "0",
      "margin_bottom": "34px",
      "line_height": "1.3",
      "letter_spacing": "0.05em",
      "box_shadow": "0 6px 20px rgba(124,58,237,0.2)",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "600",
      "color": "#7c3aed",
      "line_height": "1.4",
      "margin_top": "34px",
      "margin_bottom": "16px",
      "padding_left": "12px",
      "border_left": "4px solid",
      "border_image": "linear-gradient(to bottom, #7c3aed, #10b981) 1",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h3": {
      "font_size": "19px",
      "font_weight": "600",
      "color": "#6366f1",
      "line_height": "1.4",
      "margin_top": "26px",
      "margin_bottom": "14px",
      "padding": "6px 14px",
      "background": "linear-gradient(90deg, rgba(124,58,237,0.06), rgba(16,185,129,0.06))",
      "border_radius": "8px",
      "border_left": "3px solid #7c3aed",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#383844",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "blockquote": {
      "border_left": "3px solid #7c3aed",
      "border_image": "linear-gradient(to bottom, #7c3aed, #10b981) 1",
      "background": "rgba(124,58,237,0.03)",
      "padding": "18px 22px",
      "border_radius": "10px",
      "margin_top": "16px",
      "margin_bottom": "22px",
      "font_size": "14px",
      "color": "#5a5a77",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#5a5a77",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#7c3aed",
      "background": "linear-gradient(90deg, rgba(124,58,237,0.1), rgba(16,185,129,0.1))",
      "padding": "0 3px",
      "border_radius": "3px"
    },
    "em": {
      "font_style": "italic",
      "color": "#6366f1"
    },
    "a": {
      "color": "#7c3aed",
      "text_decoration": "none",
      "border_bottom": "1px solid rgba(124,58,237,0.3)"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "10px",
      "display": "block",
      "box_shadow": "0 4px 16px rgba(124,58,237,0.1)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "12px",
      "padding": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "margin_top": "38px",
      "margin_bottom": "38px",
      "height": "2px",
      "background": "linear-gradient(to right, transparent, #7c3aed, #6366f1, #10b981, transparent)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "#f8f6ff",
      "padding": "3px 8px",
      "border_radius": "6px",
      "font_size": "90%",
      "color": "#7c3aed",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#f8f6ff",
      "border_radius": "10px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "box_shadow": "0 2px 10px rgba(124,58,237,0.06)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "linear-gradient(90deg, rgba(124,58,237,0.08), rgba(16,185,129,0.08))"
    },
    "pre": {
      "background": "#f8f6ff",
      "color": "#383844",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#383844",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "10px",
      "overflow": "hidden",
      "box_shadow": "0 2px 8px rgba(124,58,237,0.05)"
    },
    "th": {
      "background": "linear-gradient(135deg, rgba(124,58,237,0.1), rgba(16,185,129,0.1))",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#7c3aed",
      "border_bottom": "2px solid rgba(124,58,237,0.15)",
      "font_size": "12px",
      "letter_spacing": "0.04em"
    },
    "td": {
      "padding": "12px 16px",
      "font_size": "14px",
      "line_height": "1.65",
      "background": "#ffffff",
      "color": "#383844",
      "border_bottom": "1px solid rgba(124,58,237,0.04)"
    },
    "list_item_bullet": {
      "color": "#7c3aed",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "linear-gradient(135deg, #7c3aed, #6366f1)",
      "color": "#ffffff",
      "border_radius": "50%",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#383844",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "34px",
      "padding_top": "16px",
      "border_top": "1px dashed rgba(124,58,237,0.15)"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "500",
      "color": "#9988aa",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#9988aa",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#7c3aed",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "linear-gradient(135deg, rgba(124,58,237,0.04), rgba(16,185,129,0.04))",
      "border_left": "3px solid #7c3aed",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "10px"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#7c3aed",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#5a5a77",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "#6366f1",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#776688",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#9988aa",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    }
  }
}