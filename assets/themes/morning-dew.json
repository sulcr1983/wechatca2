{
  "name": "晨露·青",
  "description": "清晨露珠 #5b9a68 + 浅米底 #f9faf6，清新自然田园风格，适合健康养生、园艺生活、环保内容",
  "colors": {
    "primary": "#4a8a55",
    "accent": "#5b9a68",
    "background": "#f9faf6",
    "blockquote_bg": "rgba(91,154,104,0.04)",
    "code_bg": "#f4f7f0",
    "hr_color": "#5b9a68",
    "footnote_bg": "#f9faf6"
  },
  "styles": {
    "wrapper": { "background_color": "#f9faf6", "padding": "16px" },
    "h1": { "font_size": "25px", "font_weight": "600", "color": "#4a8a55", "line_height": "1.4", "margin_top": "0", "margin_bottom": "30px", "text_align": "center", "letter_spacing": "0.05em", "padding": "16px 0", "border_top": "2px solid #7db888", "border_bottom": "2px solid #7db888" },
    "h2": { "font_size": "20px", "font_weight": "500", "color": "#4a8a55", "line_height": "1.4", "margin_top": "30px", "margin_bottom": "14px", "padding_left": "12px", "border_left": "3px solid #7db888", "letter_spacing": "0.03em" },
    "h3": { "font_size": "17px", "font_weight": "500", "color": "#6aaa70", "line_height": "1.4", "margin_top": "22px", "margin_bottom": "12px", "padding": "4px 0", "border_bottom": "1px dotted rgba(91,154,104,0.25)" },
    "p": { "font_size": "15px", "color": "#3a4438", "line_height": "1.8", "margin_top": "0", "margin_bottom": "18px", "letter_spacing": "0.03em", "text_align": "left" },
    "blockquote": { "border_left": "3px solid #7db888", "background": "rgba(125,184,136,0.06)", "padding": "16px 20px", "border_radius": "8px", "margin_top": "14px", "margin_bottom": "20px", "font_size": "14px", "color": "#556650", "line_height": "1.8" },
    "blockquote_p": { "font_size": "14px", "color": "#556650", "line_height": "1.8", "margin_bottom": "0" },
    "strong": { "font_weight": "600", "color": "#3a7a44" },
    "em": { "font_style": "italic", "color": "#5b9a68" },
    "a": { "color": "#5b9a68", "text_decoration": "none" },
    "img": { "max_width": "100%", "border_radius": "10px", "display": "block", "box_shadow": "0 2px 10px rgba(91,154,104,0.1)" },
    "img_wrapper": { "background": "#ffffff", "border_radius": "12px", "padding": "5px", "margin_top": "14px", "margin_bottom": "14px" },
    "hr": { "margin_top": "30px", "margin_bottom": "30px", "height": "1px", "background": "linear-gradient(to right, transparent, rgba(125,184,136,0.3), rgba(125,184,136,0.3), transparent)", "border": "none", "width": "60%" },
    "code": { "background": "#f4f7f0", "padding": "2px 8px", "border_radius": "6px", "font_size": "90%", "color": "#4a8a55", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "code_block": { "background": "#f4f7f0", "border_radius": "8px", "margin_top": "16px", "margin_bottom": "16px", "overflow": "hidden", "border": "1px solid rgba(125,184,136,0.15)" },
    "code_header": { "display": "flex", "align_items": "center", "height": "28px", "padding": "0 10px", "background": "rgba(125,184,136,0.08)" },
    "pre": { "background": "#f4f7f0", "color": "#3a4438", "padding": "14px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.45", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#3a4438", "font_size": "13px", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "16px", "margin_bottom": "16px", "font_size": "14px", "border_spacing": "0", "border_radius": "8px", "overflow": "hidden", "box_shadow": "0 1px 6px rgba(91,154,104,0.05)" },
    "th": { "background": "rgba(125,184,136,0.1)", "padding": "10px 14px", "text_align": "left", "font_weight": "500", "color": "#4a8a55", "border_bottom": "1px solid rgba(125,184,136,0.18)", "font_size": "12px" },
    "td": { "padding": "10px 14px", "font_size": "13px", "line_height": "1.6", "background": "#ffffff", "color": "#3a4438", "border_bottom": "1px solid rgba(125,184,136,0.05)" },
    "list_item_bullet": { "color": "#7db888", "margin_right": "8px", "font_weight": "bold" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "20px", "height": "20px", "min_width": "20px", "background": "rgba(125,184,136,0.12)", "color": "#4a8a55", "border_radius": "50%", "font_size": "11px", "font_weight": "500", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#3a4438", "line_height": "1.8", "letter_spacing": "0.03em" },
    "list_wrapper": { "margin_top": "14px", "margin_bottom": "14px" },
    "list_item_row": { "display": "flex", "margin_bottom": "5px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "28px", "padding_top": "14px", "border_top": "1px dashed rgba(125,184,136,0.2)" },
    "footnote_title": { "font_size": "12px", "font_weight": "500", "color": "#889988", "margin_bottom": "8px" },
    "footnote_item": { "font_size": "11px", "color": "#889988", "margin_bottom": "4px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "10px", "color": "#7db888", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "rgba(125,184,136,0.06)", "border_left": "3px solid #7db888", "padding": "14px 18px", "margin_top": "14px", "margin_bottom": "14px", "border_radius": "8px" },
    "callout_title": { "font_weight": "500", "color": "#4a8a55", "margin_bottom": "6px", "font_size": "14px" },
    "callout_content": { "font_size": "13px", "color": "#556650", "line_height": "1.8", "letter_spacing": "0.03em" },
    "h4": { "font_size": "16px", "font_weight": "500", "color": "#4a8a55", "padding": "0", "margin_top": "20px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "400", "color": "#667766", "padding": "0", "margin_top": "16px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#889988", "padding": "0", "margin_top": "12px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}