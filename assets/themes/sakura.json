{
  "name": "樱花·粉",
  "description": "温柔樱花粉 #f8a5c0 + 米白底 #fffaf8，柔和浪漫日系风格，适合生活随笔、情感故事、女性内容",
  "colors": {
    "primary": "#e898a8",
    "accent": "#f0b0c0",
    "background": "#fffaf8",
    "blockquote_bg": "rgba(240,176,192,0.06)",
    "code_bg": "#fff5f5",
    "hr_color": "#f0b0c0",
    "footnote_bg": "#fffaf8"
  },
  "styles": {
    "wrapper": { "background_color": "#fffaf8", "padding": "16px" },
