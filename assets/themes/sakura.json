    "code": { "background": "#fff5f5", "padding": "3px 8px", "border_radius": "8px", "font_size": "90%", "color": "#d87890", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "code_block": { "background": "#fff5f5", "border_radius": "10px", "margin_top": "18px", "margin_bottom": "18px", "overflow": "hidden", "box_shadow": "0 2px 8px rgba(232,152,168,0.06)" },
    "code_header": { "display": "flex", "align_items": "center", "height": "30px", "padding": "0 12px", "background": "rgba(240,176,192,0.1)" },
    "pre": { "background": "#fff5f5", "color": "#5a4a4a", "padding": "16px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.5", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#5a4a4a", "font_size": "13px", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "18px", "margin_bottom": "18px", "font_size": "14px", "border_spacing": "0", "border_radius": "12px", "overflow": "hidden", "box_shadow": "0 2px 8px rgba(232,152,168,0.06)" },
