    "list_item_bullet": { "color": "#f0b0c0", "margin_right": "8px", "font_weight": "bold" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "22px", "height": "22px", "min_width": "22px", "background": "rgba(240,176,192,0.12)", "color": "#d87890", "border_radius": "50%", "font_size": "12px", "font_weight": "500", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#5a4a4a", "line_height": "1.85", "letter_spacing": "0.04em" },
    "list_wrapper": { "margin_top": "16px", "margin_bottom": "16px" },
    "list_item_row": { "display": "flex", "margin_bottom": "6px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "32px", "padding_top": "16px", "border_top": "1px dashed rgba(240,176,192,0.2)" },
    "footnote_title": { "font_size": "13px", "font_weight": "500", "color": "#aa99a0", "margin_bottom": "10px" },
    "footnote_item": { "font_size": "12px", "color": "#aa99a0", "margin_bottom": "6px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "11px", "color": "#f0b0c0", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "rgba(240,176,192,0.06)", "border_left": "3px solid #f0b0c0", "padding": "16px 20px", "margin_top": "16px", "margin_bottom": "16px", "border_radius": "12px" },
    "callout_title": { "font_weight": "500", "color": "#d87890", "margin_bottom": "8px", "font_size": "15px" },
    "callout_content": { "font_size": "14px", "color": "#886868", "line_height": "1.8", "letter_spacing": "0.04em" },
    "h4": { "font_size": "17px", "font_weight": "500", "color": "#d87890", "padding": "0", "margin_top": "22px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "400", "color": "#887878", "padding": "0", "margin_top": "18px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#aa8888", "padding": "0", "margin_top": "14px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}