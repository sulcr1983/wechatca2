    "h2": { "font_size": "21px", "font_weight": "500", "color": "#d87890", "line_height": "1.4", "margin_top": "32px", "margin_bottom": "16px", "padding_left": "12px", "border_left": "3px solid #f0b0c0", "letter_spacing": "0.04em" },
    "h3": { "font_size": "18px", "font_weight": "500", "color": "#e898a8", "line_height": "1.4", "margin_top": "24px", "margin_bottom": "14px", "padding": "6px 12px", "background": "rgba(240,176,192,0.06)", "border_radius": "12px" },
    "p": { "font_size": "15px", "color": "#5a4a4a", "line_height": "1.85", "margin_top": "0", "margin_bottom": "20px", "letter_spacing": "0.04em", "text_align": "left" },
    "blockquote": { "border_left": "3px solid #f0b0c0", "background": "rgba(240,176,192,0.06)", "padding": "18px 22px", "border_radius": "12px", "margin_top": "16px", "margin_bottom": "22px", "font_size": "15px", "color": "#886868", "line_height": "1.8" },
    "blockquote_p": { "font_size": "15px", "color": "#886868", "line_height": "1.8", "margin_bottom": "0" },
    "strong": { "font_weight": "600", "color": "#d87890" },
    "em": { "font_style": "italic", "color": "#c07080" },
    "a": { "color": "#e898a8", "text_decoration": "none" },
