{
  "name": "合同·灰",
  "description": "专业合同灰 #3a4048 + 条纹表格，规范严谨的商务风格，适合法律文书、公司制度、正式通告",
  "colors": {
    "primary": "#3a4048",
    "accent": "#556677",
    "background": "#ffffff",
    "blockquote_bg": "#f6f7f8",
    "code_bg": "#f4f5f6",
    "hr_color": "#3a4048",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": { "background_color": "#ffffff", "padding": "16px" },
    "h1": { "font_size": "24px", "font_weight": "600", "color": "#3a4048", "line_height": "1.4", "margin_top": "0", "margin_bottom": "30px", "letter_spacing": "0.06em", "padding": "12px 18px", "border": "1px solid #3a4048", "border_left": "5px solid #3a4048", "text_align": "left" },
    "h2": { "font_size": "20px", "font_weight": "600", "color": "#3a4048", "line_height": "1.4", "margin_top": "30px", "margin_bottom": "14px", "padding": "0 0 8px 0", "border_bottom": "2px solid #3a4048", "letter_spacing": "0.04em" },
    "h3": { "font_size": "17px", "font_weight": "600", "color": "#3a4048", "line_height": "1.4", "margin_top": "22px", "margin_bottom": "12px", "padding": "0", "letter_spacing": "0.03em" },
    "p": { "font_size": "15px", "color": "#2a3038", "line_height": "1.75", "margin_top": "0", "margin_bottom": "16px", "letter_spacing": "0.01em", "text_align": "left" },
    "blockquote": { "border_left": "3px solid #3a4048", "background": "#f6f7f8", "padding": "14px 20px", "border_radius": "2px", "margin_top": "14px", "margin_bottom": "20px", "font_size": "14px", "color": "#556677", "line_height": "1.75" },
    "blockquote_p": { "font_size": "14px", "color": "#556677", "line_height": "1.75", "margin_bottom": "0" },
    "strong": { "font_weight": "700", "color": "#1a2028" },
    "em": { "font_style": "italic", "color": "#556677" },
    "a": { "color": "#3a4048", "text_decoration": "none", "border_bottom": "1px solid #3a4048" },
    "img": { "max_width": "100%", "border_radius": "2px", "display": "block", "border": "1px solid #d0d4d8" },
    "img_wrapper": { "background": "#ffffff", "border_radius": "2px", "padding": "2px", "margin_top": "14px", "margin_bottom": "14px" },
    "hr": { "margin_top": "28px", "margin_bottom": "28px", "height": "1px", "background": "#3a4048", "border": "none", "width": "100%" },
    "code": { "background": "#f4f5f6", "padding": "2px 6px", "border_radius": "2px", "font_size": "90%", "color": "#3a4048", "font_family": "'Courier New', Menlo, Monaco, monospace" },
    "code_block": { "background": "#f4f5f6", "border_radius": "2px", "margin_top": "16px", "margin_bottom": "16px", "overflow": "hidden", "border": "1px solid #d0d4d8" },
    "code_header": { "display": "flex", "align_items": "center", "height": "28px", "padding": "0 10px", "background": "#e0e3e6" },
    "pre": { "background": "#f4f5f6", "color": "#2a3038", "padding": "14px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.45", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#2a3038", "font_size": "13px", "font_family": "'Courier New', Menlo, Monaco, monospace" },
    "table": { "width": "100%", "border_collapse": "collapse", "margin_top": "16px", "margin_bottom": "16px", "font_size": "14px", "border": "1px solid #3a4048" },
    "th": { "background": "#3a4048", "padding": "10px 14px", "text_align": "left", "font_weight": "600", "color": "#ffffff", "border": "1px solid #3a4048", "font_size": "12px", "letter_spacing": "0.04em" },
    "td": { "padding": "10px 14px", "font_size": "13px", "line_height": "1.6", "background": "#ffffff", "color": "#2a3038", "border": "1px solid #c0c4c8" },
    "list_item_bullet": { "color": "#3a4048", "margin_right": "8px", "font_weight": "bold", "content": "▪" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "22px", "height": "22px", "min_width": "22px", "background": "#3a4048", "color": "#ffffff", "border_radius": "2px", "font_size": "12px", "font_weight": "600", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#2a3038", "line_height": "1.75", "letter_spacing": "0.01em" },
    "list_wrapper": { "margin_top": "14px", "margin_bottom": "14px" },
    "list_item_row": { "display": "flex", "margin_bottom": "5px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "28px", "padding_top": "14px", "border_top": "1px solid #d0d4d8" },
    "footnote_title": { "font_size": "11px", "font_weight": "600", "color": "#889999", "margin_bottom": "8px", "letter_spacing": "0.04em" },
    "footnote_item": { "font_size": "10px", "color": "#889999", "margin_bottom": "4px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "9px", "color": "#3a4048", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "#f6f7f8", "border_left": "4px solid #3a4048", "padding": "14px 18px", "margin_top": "14px", "margin_bottom": "14px", "border_radius": "2px" },
    "callout_title": { "font_weight": "600", "color": "#3a4048", "margin_bottom": "6px", "font_size": "14px", "letter_spacing": "0.03em" },
    "callout_content": { "font_size": "13px", "color": "#556677", "line_height": "1.75", "letter_spacing": "0.01em" },
    "h4": { "font_size": "16px", "font_weight": "600", "color": "#3a4048", "padding": "0", "margin_top": "20px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "500", "color": "#556677", "padding": "0", "margin_top": "16px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#778899", "padding": "0", "margin_top": "12px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}