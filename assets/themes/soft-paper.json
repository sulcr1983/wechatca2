{
  "name": "柔纸·米",
  "description": "柔和米白 #faf7f0 + 咖啡棕 #8b6c5c，温暖纸质阅读感，适合散文随笔、心情日记、私享内容",
  "colors": {
    "primary": "#8b6c5c",
    "accent": "#a08060",
    "background": "#faf7f0",
    "blockquote_bg": "#f5f0e8",
    "code_bg": "#f3efe4",
    "hr_color": "#c0b0a0",
    "footnote_bg": "#faf7f0"
  },
  "styles": {
    "wrapper": { "background_color": "#faf7f0", "padding": "16px" },
    "h1": { "font_size": "24px", "font_weight": "500", "color": "#6b4c3c", "line_height": "1.6", "margin_top": "0", "margin_bottom": "30px", "text_align": "center", "letter_spacing": "0.08em", "padding": "12px 0", "border_bottom": "2px solid #c0b0a0" },
    "h2": { "font_size": "20px", "font_weight": "500", "color": "#6b4c3c", "line_height": "1.5", "margin_top": "28px", "margin_bottom": "14px", "padding_left": "10px", "border_left": "2px solid #a08060", "letter_spacing": "0.05em" },
    "h3": { "font_size": "17px", "font_weight": "500", "color": "#8b6c5c", "line_height": "1.5", "margin_top": "22px", "margin_bottom": "12px", "padding": "0 0 4px 0", "border_bottom": "1px dotted #c0b0a0" },
    "p": { "font_size": "15px", "color": "#5a4038", "line_height": "1.85", "margin_top": "0", "margin_bottom": "20px", "letter_spacing": "0.04em", "text_align": "left" },
    "blockquote": { "border_left": "2px solid #a08060", "background": "#f5f0e8", "padding": "16px 20px", "border_radius": "6px", "margin_top": "14px", "margin_bottom": "20px", "font_size": "14px", "color": "#887060", "line_height": "1.8" },
    "blockquote_p": { "font_size": "14px", "color": "#887060", "line_height": "1.8", "margin_bottom": "0" },
    "strong": { "font_weight": "600", "color": "#6b4c3c" },
    "em": { "font_style": "italic", "color": "#a08060" },
    "a": { "color": "#8b6c5c", "text_decoration": "none", "border_bottom": "1px solid #c0b0a0" },
    "img": { "max_width": "100%", "border_radius": "8px", "display": "block", "box_shadow": "0 2px 8px rgba(0,0,0,0.05)" },
    "img_wrapper": { "background": "#ffffff", "border_radius": "10px", "padding": "6px", "margin_top": "14px", "margin_bottom": "14px" },
    "hr": { "margin_top": "32px", "margin_bottom": "32px", "height": "1px", "background": "linear-gradient(to right, transparent, #c0b0a0, transparent)", "border": "none", "width": "70%" },
    "code": { "background": "#f3efe4", "padding": "2px 8px", "border_radius": "4px", "font_size": "90%", "color": "#8b6c5c", "font_family": "Menlo, Monaco, monospace" },
    "code_block": { "background": "#f3efe4", "border_radius": "6px", "margin_top": "16px", "margin_bottom": "16px", "overflow": "hidden", "border": "1px solid #e0d8cc" },
    "code_header": { "display": "flex", "align_items": "center", "height": "28px", "padding": "0 10px", "background": "#e8e0d4" },
    "pre": { "background": "#f3efe4", "color": "#5a4038", "padding": "14px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.45", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#5a4038", "font_size": "13px", "font_family": "Menlo, Monaco, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "16px", "margin_bottom": "16px", "font_size": "14px", "border_spacing": "0", "border_radius": "8px", "overflow": "hidden", "border": "1px solid #e0d8cc" },
    "th": { "background": "#f5f0e8", "padding": "10px 14px", "text_align": "left", "font_weight": "500", "color": "#6b4c3c", "border_bottom": "1px solid #c0b0a0", "font_size": "12px" },
    "td": { "padding": "10px 14px", "font_size": "13px", "line_height": "1.6", "background": "#ffffff", "color": "#5a4038", "border_bottom": "1px solid #e0d8cc" },
    "list_item_bullet": { "color": "#a08060", "margin_right": "8px", "font_weight": "bold" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "20px", "height": "20px", "min_width": "20px", "background": "rgba(160,128,96,0.12)", "color": "#8b6c5c", "border_radius": "50%", "font_size": "11px", "font_weight": "500", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#5a4038", "line_height": "1.85", "letter_spacing": "0.04em" },
    "list_wrapper": { "margin_top": "14px", "margin_bottom": "14px" },
    "list_item_row": { "display": "flex", "margin_bottom": "5px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "30px", "padding_top": "14px", "border_top": "1px dashed #c0b0a0" },
    "footnote_title": { "font_size": "12px", "font_weight": "500", "color": "#aa9988", "margin_bottom": "8px" },
    "footnote_item": { "font_size": "11px", "color": "#aa9988", "margin_bottom": "4px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "10px", "color": "#a08060", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "#f5f0e8", "border_left": "2px solid #a08060", "padding": "14px 18px", "margin_top": "14px", "margin_bottom": "14px", "border_radius": "6px" },
    "callout_title": { "font_weight": "500", "color": "#6b4c3c", "margin_bottom": "6px", "font_size": "14px" },
    "callout_content": { "font_size": "13px", "color": "#887060", "line_height": "1.8", "letter_spacing": "0.04em" },
    "h4": { "font_size": "16px", "font_weight": "500", "color": "#6b4c3c", "padding": "0", "margin_top": "20px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "400", "color": "#887060", "padding": "0", "margin_top": "16px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#aa8870", "padding": "0", "margin_top": "12px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}