{
  "name": "几何·立体",
  "description": "硬朗几何 #4a5ef0 + 纯白底，三角阴影立体感，适合设计创意、产品发布、现代艺术内容",
  "colors": {
    "primary": "#3a4ed0",
    "accent": "#4a5ef0",
    "background": "#ffffff",
    "blockquote_bg": "#f8f9ff",
    "code_bg": "#f5f6fc",
    "hr_color": "#4a5ef0",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#ffffff",
      "background": "linear-gradient(135deg, #3a4ed0 0%, #4a5ef0 100%)",
      "padding": "16px 24px",
      "border_radius": "0",
      "clip_path": "polygon(0 0, 100% 0, 95% 100%, 0% 100%)",
      "margin_top": "0",
      "margin_bottom": "32px",
      "line_height": "1.4",
      "letter_spacing": "0.05em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h2": {
      "font_size": "21px",
      "font_weight": "700",
      "color": "#3a4ed0",
      "line_height": "1.4",
      "margin_top": "32px",
      "margin_bottom": "16px",
      "padding": "0",
      "border_left": "4px solid #4a5ef0",
      "padding_left": "12px",
      "letter_spacing": "0.04em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h3": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#3a4ed0",
      "line_height": "1.4",
      "margin_top": "24px",
      "margin_bottom": "14px",
      "padding": "8px 14px",
      "background": "rgba(74,94,240,0.06)",
      "border_radius": "0 8px 8px 0",
      "border_left": "3px solid #4a5ef0",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#2a2e44",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "blockquote": {
      "border_left": "0",
      "background": "#f8f9ff",
      "padding": "18px 22px",
      "border_radius": "0 12px 12px 0",
      "margin_top": "16px",
      "margin_bottom": "22px",
      "font_size": "14px",
      "color": "#555a77",
      "line_height": "1.8",
      "box_shadow": "4px 4px 0 rgba(74,94,240,0.08)"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#555a77",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#3a4ed0"
    },
    "em": {
      "font_style": "italic",
      "color": "#4a5ef0"
    },
    "a": {
      "color": "#4a5ef0",
      "text_decoration": "none",
      "border_bottom": "2px solid rgba(74,94,240,0.2)"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "0",
      "display": "block",
      "box_shadow": "6px 6px 0 rgba(74,94,240,0.08)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "0",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "20px"
    },
    "hr": {
      "margin_top": "36px",
      "margin_bottom": "36px",
      "height": "3px",
      "width": "40px",
      "background": "#4a5ef0",
      "border": "none"
    },
    "code": {
      "background": "#f5f6fc",
      "padding": "3px 8px",
      "border_radius": "4px",
      "font_size": "90%",
      "color": "#4a5ef0",
      "font_family": "'SF Mono', Menlo, Monaco, monospace"
    },
    "code_block": {
      "background": "#f5f6fc",
      "border_radius": "0",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "box_shadow": "4px 4px 0 rgba(74,94,240,0.06)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "rgba(74,94,240,0.06)"
    },
    "pre": {
      "background": "#f5f6fc",
      "color": "#2a2e44",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#2a2e44",
      "font_size": "13px",
      "font_family": "'SF Mono', Menlo, Monaco, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "0",
      "overflow": "hidden",
      "box_shadow": "4px 4px 0 rgba(74,94,240,0.06)"
    },
    "th": {
      "background": "#3a4ed0",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#ffffff",
      "font_size": "12px",
      "letter_spacing": "0.06em"
    },
    "td": {
      "padding": "12px 16px",
      "font_size": "14px",
      "line_height": "1.65",
      "background": "#ffffff",
      "color": "#2a2e44",
      "border_bottom": "1px solid #eef0f8"
    },
    "list_item_bullet": {
      "color": "#4a5ef0",
      "margin_right": "8px",
      "font_weight": "bold",
      "content": "■"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "#3a4ed0",
      "color": "#ffffff",
      "border_radius": "0",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#2a2e44",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #eef0f8"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#889999",
      "margin_bottom": "10px",
      "letter_spacing": "0.05em"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#889999",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#4a5ef0",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f8f9ff",
      "border_left": "4px solid #4a5ef0",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0 8px 8px 0",
      "box_shadow": "4px 4px 0 rgba(74,94,240,0.06)"
    },
    "callout_title": {
      "font_weight": "700",
      "color": "#3a4ed0",
      "margin_bottom": "8px",
      "font_size": "15px",
      "letter_spacing": "0.04em"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#555a77",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "700",
      "color": "#3a4ed0",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "600",
      "color": "#555a77",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "500",
      "color": "#778899",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', sans-serif"
    }
  }
}