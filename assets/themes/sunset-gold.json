{
  "name": "落日·金",
  "description": "壮丽落日 #f0a030 + 深棕底 #1a1410，金色温暖浓郁，适合旅行游记、摄影分享、抒情散文",
  "colors": {
    "primary": "#f0a030",
    "accent": "#e89828",
    "background": "#fffdf8",
    "blockquote_bg": "rgba(240,160,48,0.05)",
    "code_bg": "#fffaf0",
    "hr_color": "#f0a030",
    "footnote_bg": "#fffdf8"
  },
  "styles": {
    "wrapper": {
      "background_color": "#fffdf8",
      "padding": "16px"
    },
    "h1": {
      "font_size": "28px",
      "font_weight": "700",
      "color": "#1a1410",
      "line_height": "1.3",
      "margin_top": "0",
      "margin_bottom": "34px",
      "text_align": "center",
      "letter_spacing": "0.06em",
      "padding": "20px 0",
      "border_top": "3px solid #f0a030",
      "border_bottom": "3px solid #f0a030",
      "font_family": "Georgia, serif"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "600",
      "color": "#1a1410",
      "line_height": "1.4",
      "margin_top": "34px",
      "margin_bottom": "16px",
      "padding_bottom": "8px",
      "border_bottom": "2px solid rgba(240,160,48,0.3)",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h3": {
      "font_size": "19px",
      "font_weight": "600",
      "color": "#e89828",
      "line_height": "1.4",
      "margin_top": "26px",
      "margin_bottom": "12px",
      "padding_left": "10px",
      "border_left": "3px solid #f0a030",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#3a3028",
      "line_height": "1.85",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.03em",
      "text_align": "left",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "blockquote": {
      "border_left": "3px solid #f0a030",
      "background": "rgba(240,160,48,0.05)",
      "padding": "18px 22px",
      "border_radius": "6px",
      "margin_top": "16px",
      "margin_bottom": "22px",
      "font_size": "15px",
      "color": "#6a5840",
      "line_height": "1.85"
    },
    "blockquote_p": {
      "font_size": "15px",
      "color": "#6a5840",
      "line_height": "1.85",
      "margin_bottom": "0",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#c87820"
    },
    "em": {
      "font_style": "italic",
      "color": "#a06828"
    },
    "a": {
      "color": "#e89828",
      "text_decoration": "none",
      "border_bottom": "1px dashed #f0a030"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "8px",
      "display": "block",
      "box_shadow": "0 4px 14px rgba(0,0,0,0.1)"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "10px",
      "padding": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "margin_top": "36px",
      "margin_bottom": "36px",
      "height": "2px",
      "background": "linear-gradient(to right, transparent, #f0a030, transparent)",
      "border": "none",
      "width": "50%"
    },
    "code": {
      "background": "#fffaf0",
      "padding": "2px 8px",
      "border_radius": "6px",
      "font_size": "90%",
      "color": "#c87820",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#fffaf0",
      "border_radius": "8px",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "border": "1px solid rgba(240,160,48,0.12)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "30px",
      "padding": "0 12px",
      "background": "rgba(240,160,48,0.08)"
    },
    "pre": {
      "background": "#fffaf0",
      "color": "#3a3028",
      "padding": "14px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#3a3028",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "8px",
      "overflow": "hidden",
      "box_shadow": "0 2px 8px rgba(0,0,0,0.04)"
    },
    "th": {
      "background": "rgba(240,160,48,0.12)",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#c87820",
      "border_bottom": "2px solid rgba(240,160,48,0.2)",
      "font_size": "13px"
    },
    "td": {
      "padding": "12px 16px",
      "font_size": "14px",
      "line_height": "1.65",
      "background": "#ffffff",
      "color": "#3a3028",
      "border_bottom": "1px solid rgba(240,160,48,0.06)"
    },
    "list_item_bullet": {
      "color": "#f0a030",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(240,160,48,0.15)",
      "color": "#c87820",
      "border_radius": "50%",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#3a3028",
      "line_height": "1.85",
      "letter_spacing": "0.03em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "34px",
      "padding_top": "16px",
      "border_top": "1px dashed rgba(240,160,48,0.25)"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "500",
      "color": "#aa9988",
      "margin_bottom": "10px"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#aa9988",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#f0a030",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(240,160,48,0.06)",
      "border_left": "3px solid #f0a030",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "8px"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#c87820",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#6a5840",
      "line_height": "1.8",
      "letter_spacing": "0.03em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "#c87820",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#887058",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#aa8868",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    }
  }
}