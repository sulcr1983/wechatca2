{
  "name": "Vogue·时尚",
  "description": "衬线体杂志风 #1a1a1a 大标题 + Didot 风格，高对比度排版，适合时尚、生活方式、品牌内容",
  "colors": {
    "primary": "#1a1a1a",
    "accent": "#c41230",
    "background": "#ffffff",
    "blockquote_bg": "#faf8f6",
    "code_bg": "#f5f4f0",
    "hr_color": "#c41230",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": {
      "background_color": "#ffffff",
      "padding": "16px"
    },
    "h1": {
      "font_size": "32px",
      "font_weight": "700",
      "color": "#1a1a1a",
      "line_height": "1.15",
      "letter_spacing": "0.08em",
      "margin_top": "0",
      "margin_bottom": "40px",
      "text_align": "center",
      "font_family": "Georgia, 'Times New Roman', serif",
      "padding": "0",
      "text_transform": "uppercase"
    },
    "h2": {
      "font_size": "24px",
      "font_weight": "600",
      "color": "#1a1a1a",
      "line_height": "1.3",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif",
      "margin_top": "40px",
      "margin_bottom": "20px",
      "text_align": "center",
      "letter_spacing": "0.05em",
      "padding": "0"
    },
    "h3": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#c41230",
      "line_height": "1.4",
      "margin_top": "32px",
      "margin_bottom": "14px",
      "text_align": "center",
      "letter_spacing": "0.04em",
      "padding": "0",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "p": {
      "font_size": "16px",
      "color": "#2a2a2a",
      "line_height": "1.9",
      "margin_top": "0",
      "margin_bottom": "24px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "blockquote": {
      "border_left": "3px solid #c41230",
      "background": "#faf8f6",
      "padding": "24px 28px",
      "border_radius": "0",
      "margin_top": "20px",
      "margin_bottom": "28px",
      "font_size": "18px",
      "color": "#444444",
      "line_height": "1.8",
      "font_style": "italic",
      "font_family": "Georgia, serif"
    },
    "blockquote_p": {
      "font_size": "18px",
      "color": "#444444",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_style": "italic",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#1a1a1a"
    },
    "em": {
      "font_style": "italic",
      "color": "#c41230"
    },
    "a": {
      "color": "#c41230",
      "text_decoration": "none",
      "border_bottom": "1px solid #c41230"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "0",
      "display": "block"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "20px"
    },
    "hr": {
      "margin_top": "48px",
      "margin_bottom": "48px",
      "height": "2px",
      "background": "linear-gradient(to right, #c41230, transparent 70%)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "#f5f4f0",
      "padding": "3px 8px",
      "border_radius": "2px",
      "font_size": "90%",
      "color": "#c41230",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#f5f4f0",
      "border_radius": "0",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "overflow": "hidden",
      "border": "1px solid #e8e4dc"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "#e8e4dc"
    },
    "pre": {
      "background": "#f5f4f0",
      "color": "#2a2a2a",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#2a2a2a",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "24px",
      "margin_bottom": "24px",
      "font_size": "15px",
      "border_spacing": "0",
      "overflow": "hidden"
    },
    "th": {
      "background": "#1a1a1a",
      "padding": "14px 18px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#ffffff",
      "border_bottom": "2px solid #1a1a1a",
      "font_size": "13px",
      "letter_spacing": "0.05em"
    },
    "td": {
      "padding": "14px 18px",
      "font_size": "14px",
      "line_height": "1.7",
      "background": "#ffffff",
      "color": "#2a2a2a",
      "border_bottom": "1px solid #e5e5e5"
    },
    "list_item_bullet": {
      "color": "#c41230",
      "margin_right": "10px",
      "font_weight": "bold",
      "font_size": "18px"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "24px",
      "height": "24px",
      "min_width": "24px",
      "background": "#1a1a1a",
      "color": "#ffffff",
      "border_radius": "0",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "10px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#2a2a2a",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "list_wrapper": {
      "margin_top": "20px",
      "margin_bottom": "20px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "8px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "40px",
      "padding_top": "16px",
      "border_top": "1px solid #e5e5e5"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#999999",
      "margin_bottom": "12px",
      "letter_spacing": "0.05em",
      "text_transform": "uppercase"
    },
    "footnote_item": {
      "font_size": "12px",
      "color": "#999999",
      "margin_bottom": "6px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "footnote_sup": {
      "font_size": "11px",
      "color": "#c41230",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#faf8f6",
      "border_left": "3px solid #1a1a1a",
      "padding": "20px 24px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "border_radius": "0"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#1a1a1a",
      "margin_bottom": "8px",
      "font_size": "16px",
      "letter_spacing": "0.05em"
    },
    "callout_content": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.8",
      "letter_spacing": "0.02em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h4": {
      "font_size": "18px",
      "font_weight": "600",
      "color": "#1a1a1a",
      "padding": "0",
      "margin_top": "28px",
      "margin_bottom": "10px",
      "line_height": "1.4",
      "text_align": "center",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#555555",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#888888",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    }
  }
}