{
  "name": "牛皮·纸",
  "description": "牛皮纸 #8b7355 + 暖褐墨色，复古手工质感，适合手作教程、文艺创作、旅人日记",
  "colors": {
    "primary": "#6b5344",
    "accent": "#c4884a",
    "background": "#f5f0e8",
    "blockquote_bg": "#f0ebe0",
    "code_bg": "#ede6d8",
    "hr_color": "#c4884a",
    "footnote_bg": "#f5f0e8"
  },
  "styles": {
    "wrapper": {
      "background_color": "#f5f0e8",
      "padding": "16px"
    },
    "h1": {
      "font_size": "24px",
      "font_weight": "700",
      "color": "#6b5344",
      "line_height": "1.5",
      "margin_top": "0",
      "margin_bottom": "28px",
      "text_align": "center",
      "letter_spacing": "0.08em",
      "padding": "12px 0",
      "border_top": "2px solid #c4884a",
      "border_bottom": "2px solid #c4884a",
      "font_family": "Georgia, serif"
    },
    "h2": {
      "font_size": "20px",
      "font_weight": "600",
      "color": "#6b5344",
      "line_height": "1.5",
      "margin_top": "28px",
      "margin_bottom": "14px",
      "padding_left": "12px",
      "border_left": "3px solid #c4884a",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h3": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "#8b6a50",
      "line_height": "1.5",
      "margin_top": "22px",
      "margin_bottom": "12px",
      "padding": "0 0 6px 0",
      "border_bottom": "1px dashed #c4884a",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#5a4438",
      "line_height": "1.85",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.04em",
      "text_align": "left",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "blockquote": {
      "border_left": "3px solid #c4884a",
      "background": "#f0ebe0",
      "padding": "14px 18px",
      "border_radius": "4px",
      "margin_top": "14px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "color": "#7a6450",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#7a6450",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#6b5344",
      "background": "linear-gradient(180deg, transparent 60%, rgba(196,136,74,0.15) 60%)",
      "padding": "0 2px"
    },
    "em": {
      "font_style": "italic",
      "color": "#8b6a50"
    },
    "a": {
      "color": "#c4884a",
      "text_decoration": "none",
      "border_bottom": "1px solid #c4884a"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "4px",
      "display": "block",
      "box_shadow": "0 2px 8px rgba(0,0,0,0.08)",
      "border": "4px solid #ffffff"
    },
    "img_wrapper": {
      "background": "#f5f0e8",
      "border_radius": "4px",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "hr": {
      "margin_top": "28px",
      "margin_bottom": "28px",
      "height": "2px",
      "background": "linear-gradient(to right, transparent, #c4884a, transparent)",
      "border": "none",
      "width": "80%"
    },
    "code": {
      "background": "#ede6d8",
      "padding": "2px 6px",
      "border_radius": "3px",
      "font_size": "90%",
      "color": "#8b6a50",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#ede6d8",
      "border_radius": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden",
      "border": "1px solid #d8cfc0"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "28px",
      "padding": "0 10px",
      "background": "#d8cfc0"
    },
    "pre": {
      "background": "#ede6d8",
      "color": "#5a4438",
      "padding": "14px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.45",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#5a4438",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "4px",
      "overflow": "hidden",
      "border": "1px solid #d8cfc0"
    },
    "th": {
      "background": "#6b5344",
      "padding": "10px 14px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#f5f0e8",
      "border_bottom": "2px solid #c4884a",
      "font_size": "12px"
    },
    "td": {
      "padding": "10px 14px",
      "font_size": "13px",
      "line_height": "1.6",
      "background": "#faf8f2",
      "color": "#5a4438",
      "border_bottom": "1px solid #d8cfc0"
    },
    "list_item_bullet": {
      "color": "#c4884a",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "20px",
      "height": "20px",
      "min_width": "20px",
      "background": "#c4884a",
      "color": "#ffffff",
      "border_radius": "50%",
      "font_size": "11px",
      "font_weight": "500",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#5a4438",
      "line_height": "1.85",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "5px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px dashed #c4884a"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "500",
      "color": "#aa9988",
      "margin_bottom": "8px"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#aa9988",
      "margin_bottom": "4px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#c4884a",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f0ebe0",
      "border_left": "3px solid #c4884a",
      "padding": "14px 18px",
      "margin_top": "14px",
      "margin_bottom": "14px",
      "border_radius": "4px"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#6b5344",
      "margin_bottom": "6px",
      "font_size": "14px"
    },
    "callout_content": {
      "font_size": "13px",
      "color": "#7a6450",
      "line_height": "1.8",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h4": {
      "font_size": "16px",
      "font_weight": "600",
      "color": "#6b5344",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h5": {
      "font_size": "15px",
      "font_weight": "500",
      "color": "#8b6a50",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#aa8870",
      "padding": "0",
      "margin_top": "12px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    }
  }
}