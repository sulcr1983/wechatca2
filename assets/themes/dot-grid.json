{
  "name": "点阵·网格",
  "description": "等宽点阵 #333333 + 浅灰网格系统，极简有序的工程师风格，适合数据可视化、知识整理、笔记分享",
  "colors": {
    "primary": "#333333",
    "accent": "#666666",
    "background": "#fafbfc",
    "blockquote_bg": "#ffffff",
    "code_bg": "#f0f2f4",
    "hr_color": "#d0d4d8",
    "footnote_bg": "#fafbfc"
  },
  "styles": {
    "wrapper": {
      "background_color": "#fafbfc",
      "padding": "16px"
    },
    "h1": {
      "font_size": "22px",
      "font_weight": "400",
      "color": "#333333",
      "line_height": "1.5",
      "margin_top": "0",
      "margin_bottom": "30px",
      "letter_spacing": "0.08em",
      "padding": "10px 16px",
      "border": "1px solid #d0d4d8",
      "border_radius": "2px",
      "background": "#ffffff",
      "font_family": "'JetBrains Mono', Consolas, monospace"
    },
    "h2": {
      "font_size": "18px",
      "font_weight": "400",
      "color": "#333333",
      "line_height": "1.5",
      "margin_top": "30px",
      "margin_bottom": "14px",
      "letter_spacing": "0.06em",
      "padding": "6px 0 8px 0",
      "border_bottom": "2px dotted #d0d4d8",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "h3": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#444444",
      "line_height": "1.5",
      "margin_top": "22px",
      "margin_bottom": "10px",
      "padding_left": "10px",
      "border_left": "2px solid #999999",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "p": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.75",
      "margin_top": "0",
      "margin_bottom": "18px",
      "letter_spacing": "0.02em",
      "text_align": "left",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "blockquote": {
      "border": "1px solid #d0d4d8",
      "border_left": "3px solid #666666",
      "background": "#ffffff",
      "padding": "14px 18px",
      "border_radius": "2px",
      "margin_top": "14px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "color": "#666666",
      "line_height": "1.7"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#666666",
      "line_height": "1.7",
      "margin_bottom": "0",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "strong": {
      "font_weight": "600",
      "color": "#222222"
    },
    "em": {
      "font_style": "italic",
      "color": "#666666"
    },
    "a": {
      "color": "#555555",
      "text_decoration": "none",
      "border_bottom": "1px solid #999999"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "2px",
      "display": "block",
      "border": "1px solid #d0d4d8"
    },
    "img_wrapper": {
      "background": "#ffffff",
      "border_radius": "2px",
      "padding": "4px",
      "margin_top": "14px",
      "margin_bottom": "14px",
      "border": "1px solid #d0d4d8"
    },
    "hr": {
      "margin_top": "28px",
      "margin_bottom": "28px",
      "height": "1px",
      "background": "repeating-linear-gradient(to right, #d0d4d8 0px, #d0d4d8 2px, transparent 2px, transparent 6px)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "#f0f2f4",
      "padding": "2px 6px",
      "border_radius": "2px",
      "font_size": "90%",
      "color": "#444444",
      "font_family": "'Courier New', Menlo, Monaco, monospace",
      "border": "1px solid #d0d4d8"
    },
    "code_block": {
      "background": "#ffffff",
      "border_radius": "2px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "overflow": "hidden",
      "border": "1px solid #d0d4d8"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "28px",
      "padding": "0 10px",
      "background": "#f0f2f4",
      "border_bottom": "1px solid #d0d4d8"
    },
    "pre": {
      "background": "#ffffff",
      "color": "#444444",
      "padding": "14px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.45",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#444444",
      "font_size": "13px",
      "font_family": "'Courier New', Menlo, Monaco, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "font_size": "14px",
      "border": "1px solid #d0d4d8"
    },
    "th": {
      "background": "#f0f2f4",
      "padding": "10px 14px",
      "text_align": "left",
      "font_weight": "500",
      "color": "#333333",
      "border": "1px solid #d0d4d8",
      "font_size": "12px",
      "letter_spacing": "0.04em"
    },
    "td": {
      "padding": "10px 14px",
      "font_size": "13px",
      "line_height": "1.6",
      "background": "#ffffff",
      "color": "#444444",
      "border": "1px solid #d0d4d8"
    },
    "list_item_bullet": {
      "color": "#666666",
      "margin_right": "8px",
      "font_weight": "normal",
      "content": "—"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "20px",
      "height": "20px",
      "min_width": "20px",
      "border": "1px solid #999999",
      "color": "#444444",
      "border_radius": "2px",
      "font_size": "11px",
      "font_weight": "400",
      "margin_right": "8px",
      "margin_top": "4px",
      "font_family": "'Courier New', monospace"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.75",
      "letter_spacing": "0.02em",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "list_wrapper": {
      "margin_top": "14px",
      "margin_bottom": "14px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "5px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "28px",
      "padding_top": "14px",
      "border_top": "1px solid #d0d4d8"
    },
    "footnote_title": {
      "font_size": "11px",
      "font_weight": "500",
      "color": "#999999",
      "margin_bottom": "8px",
      "letter_spacing": "0.05em",
      "font_family": "'Courier New', monospace"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#999999",
      "margin_bottom": "4px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#666666",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#ffffff",
      "border": "1px solid #d0d4d8",
      "border_left": "3px solid #666666",
      "padding": "14px 18px",
      "margin_top": "14px",
      "margin_bottom": "14px",
      "border_radius": "2px"
    },
    "callout_title": {
      "font_weight": "500",
      "color": "#333333",
      "margin_bottom": "6px",
      "font_size": "14px",
      "font_family": "'Courier New', monospace"
    },
    "callout_content": {
      "font_size": "13px",
      "color": "#666666",
      "line_height": "1.7",
      "letter_spacing": "0.02em",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "h4": {
      "font_size": "15px",
      "font_weight": "500",
      "color": "#444444",
      "padding": "0",
      "margin_top": "20px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "h5": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#666666",
      "padding": "0",
      "margin_top": "16px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    },
    "h6": {
      "font_size": "13px",
      "font_weight": "400",
      "color": "#888888",
      "padding": "0",
      "margin_top": "12px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'JetBrains Mono', 'Fira Code', Consolas, monospace"
    }
  }
}