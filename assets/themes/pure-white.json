{
  "name": "纯白·极简",
  "description": "极致留白 #1a1a1a 细体标题，零干扰阅读体验，适合深度长文、随笔散文",
  "colors": {
    "primary": "#1a1a1a",
    "accent": "#555555",
    "background": "#ffffff",
    "blockquote_bg": "#fafafa",
    "code_bg": "#f5f5f5",
    "hr_color": "#e5e5e5",
    "footnote_bg": "#ffffff"
  },
  "styles": {
    "wrapper": { "background_color": "#ffffff", "padding": "16px" },
    "h1": { "font_size": "24px", "font_weight": "300", "color": "#1a1a1a", "line_height": "1.5", "letter_spacing": "0.05em", "margin_top": "0", "margin_bottom": "36px", "text_align": "left", "padding": "0", "border_bottom": "1px solid #e5e5e5", "padding_bottom": "20px" },
    "h2": { "font_size": "20px", "font_weight": "400", "color": "#333333", "line_height": "1.5", "margin_top": "36px", "margin_bottom": "16px", "padding": "0", "border_left": "2px solid #e5e5e5", "padding_left": "12px" },
    "h3": { "font_size": "18px", "font_weight": "500", "color": "#444444", "line_height": "1.5", "margin_top": "28px", "margin_bottom": "12px", "padding": "0" },
    "p": { "font_size": "15px", "color": "#333333", "line_height": "1.85", "margin_top": "0", "margin_bottom": "22px", "letter_spacing": "0.03em", "text_align": "left" },
    "blockquote": { "border_left": "2px solid #d0d0d0", "background": "#fafafa", "padding": "20px 24px", "border_radius": "4px", "margin_top": "16px", "margin_bottom": "24px", "font_size": "14px", "color": "#666666", "line_height": "1.8" },
    "blockquote_p": { "font_size": "14px", "color": "#666666", "line_height": "1.8", "margin_bottom": "0" },
    "strong": { "font_weight": "600", "color": "#1a1a1a" },
    "em": { "font_style": "italic", "color": "#555555" },
    "a": { "color": "#1a1a1a", "text_decoration": "none", "border_bottom": "1px solid #d0d0d0" },
    "img": { "max_width": "100%", "border_radius": "2px", "display": "block" },
    "img_wrapper": { "background": "#ffffff", "border_radius": "2px", "padding": "0", "margin_top": "16px", "margin_bottom": "16px" },
    "hr": { "margin_top": "40px", "margin_bottom": "40px", "height": "1px", "background": "#e5e5e5", "border": "none", "width": "100%" },
    "code": { "background": "#f5f5f5", "padding": "2px 6px", "border_radius": "3px", "font_size": "90%", "color": "#555555", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "code_block": { "background": "#fafafa", "border_radius": "4px", "margin_top": "20px", "margin_bottom": "20px", "overflow": "hidden", "border": "1px solid #e5e5e5" },
    "code_header": { "display": "flex", "align_items": "center", "height": "32px", "padding": "0 12px", "background": "#f0f0f0" },
    "pre": { "background": "#fafafa", "color": "#333333", "padding": "16px", "border_radius": "0", "overflow_x": "auto", "margin_top": "0", "margin_bottom": "0", "font_size": "13px", "line_height": "1.5", "white_space": "pre-wrap", "word_wrap": "break-word", "word_break": "break-all" },
    "pre_code": { "background": "none", "padding": "0", "color": "#333333", "font_size": "13px", "font_family": "Menlo, Monaco, Consolas, monospace" },
    "table": { "width": "100%", "border_collapse": "separate", "margin_top": "20px", "margin_bottom": "20px", "font_size": "14px", "border_spacing": "0", "border_radius": "4px", "overflow": "hidden", "border": "1px solid #e5e5e5" },
    "th": { "background": "#fafafa", "padding": "12px 16px", "text_align": "left", "font_weight": "500", "color": "#555555", "border_bottom": "1px solid #e5e5e5", "font_size": "13px" },
    "td": { "padding": "12px 16px", "font_size": "14px", "line_height": "1.6", "background": "#ffffff", "color": "#333333", "border_bottom": "1px solid #f0f0f0" },
    "list_item_bullet": { "color": "#999999", "margin_right": "8px", "font_weight": "normal" },
    "ol_item_bullet": { "display": "inline-flex", "align_items": "center", "justify_content": "center", "width": "20px", "height": "20px", "min_width": "20px", "background": "#f5f5f5", "color": "#666666", "border_radius": "50%", "font_size": "12px", "font_weight": "normal", "margin_right": "8px", "margin_top": "4px" },
    "list_item_text": { "font_size": "15px", "color": "#333333", "line_height": "1.8", "letter_spacing": "0.03em" },
    "list_wrapper": { "margin_top": "16px", "margin_bottom": "16px" },
    "list_item_row": { "display": "flex", "margin_bottom": "6px", "align_items": "flex-start" },
    "footnote_section": { "margin_top": "36px", "padding_top": "16px", "border_top": "1px solid #e5e5e5" },
    "footnote_title": { "font_size": "13px", "font_weight": "500", "color": "#999999", "margin_bottom": "10px" },
    "footnote_item": { "font_size": "12px", "color": "#999999", "margin_bottom": "6px", "line_height": "1.6", "word_break": "break-all" },
    "footnote_sup": { "font_size": "11px", "color": "#999999", "vertical_align": "super", "margin_left": "2px" },
    "callout": { "background": "#fafafa", "border_left": "2px solid #333333", "padding": "16px 20px", "margin_top": "16px", "margin_bottom": "16px", "border_radius": "4px" },
    "callout_title": { "font_weight": "500", "color": "#333333", "margin_bottom": "8px", "font_size": "14px" },
    "callout_content": { "font_size": "14px", "color": "#555555", "line_height": "1.8", "letter_spacing": "0.03em" },
    "h4": { "font_size": "16px", "font_weight": "500", "color": "#444444", "padding": "0", "margin_top": "24px", "margin_bottom": "8px", "line_height": "1.4" },
    "h5": { "font_size": "15px", "font_weight": "400", "color": "#666666", "padding": "0", "margin_top": "20px", "margin_bottom": "6px", "line_height": "1.4" },
    "h6": { "font_size": "14px", "font_weight": "400", "color": "#999999", "padding": "0", "margin_top": "16px", "margin_bottom": "6px", "line_height": "1.4" }
  }
}