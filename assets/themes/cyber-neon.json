{
  "name": "赛博·霓虹",
  "description": "暗色底 #0a0a0f + 霓虹青 #00ff88，赛博朋克科技感，适合技术前沿、科幻、数字文化",
  "colors": {
    "primary": "#00ff88",
    "accent": "#00ff88",
    "background": "#0a0a0f",
    "blockquote_bg": "rgba(0,255,136,0.04)",
    "code_bg": "#12121a",
    "hr_color": "#00ff88",
    "footnote_bg": "#0a0a0f"
  },
  "styles": {
    "wrapper": {
      "background_color": "#0a0a0f",
      "padding": "16px"
    },
    "h1": {
      "font_size": "26px",
      "font_weight": "700",
      "color": "#00ff88",
      "line_height": "1.3",
      "margin_top": "0",
      "margin_bottom": "32px",
      "letter_spacing": "0.06em",
      "padding": "14px 20px",
      "border": "1px solid #00ff88",
      "border_radius": "4px",
      "text_align": "left",
      "box_shadow": "0 0 20px rgba(0,255,136,0.15)",
      "font_family": "'Orbitron', -apple-system, sans-serif"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "600",
      "color": "#00ff88",
      "line_height": "1.3",
      "margin_top": "32px",
      "margin_bottom": "18px",
      "padding_left": "12px",
      "border_left": "3px solid #00ff88",
      "letter_spacing": "0.04em",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "h3": {
      "font_size": "19px",
      "font_weight": "600",
      "color": "#00dd77",
      "line_height": "1.4",
      "margin_top": "24px",
      "margin_bottom": "14px",
      "padding": "4px 10px",
      "background": "rgba(0,255,136,0.08)",
      "border_radius": "3px",
      "border_left": "2px solid #00ff88",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "p": {
      "font_size": "15px",
      "color": "#c0c0c8",
      "line_height": "1.8",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.03em",
      "text_align": "left",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "blockquote": {
      "border_left": "3px solid #00ff88",
      "background": "rgba(0,255,136,0.04)",
      "padding": "16px 20px",
      "border_radius": "3px",
      "margin_top": "16px",
      "margin_bottom": "22px",
      "font_size": "14px",
      "color": "#a0a8b0",
      "line_height": "1.8"
    },
    "blockquote_p": {
      "font_size": "14px",
      "color": "#a0a8b0",
      "line_height": "1.8",
      "margin_bottom": "0",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#00ff88"
    },
    "em": {
      "font_style": "italic",
      "color": "#88ccff"
    },
    "a": {
      "color": "#00ff88",
      "text_decoration": "none",
      "border_bottom": "1px dashed #00ff88"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "4px",
      "display": "block",
      "border": "1px solid rgba(255,255,255,0.05)"
    },
    "img_wrapper": {
      "background": "#0a0a0f",
      "border_radius": "4px",
      "padding": "4px",
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "hr": {
      "margin_top": "32px",
      "margin_bottom": "32px",
      "height": "1px",
      "background": "linear-gradient(to right, transparent, #00ff88, transparent)",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "rgba(0,255,136,0.1)",
      "padding": "2px 8px",
      "border_radius": "3px",
      "font_size": "90%",
      "color": "#00ff88",
      "font_family": "'Courier New', Menlo, Monaco, monospace"
    },
    "code_block": {
      "background": "#12121a",
      "border_radius": "4px",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "overflow": "hidden",
      "border": "1px solid rgba(0,255,136,0.15)",
      "box_shadow": "0 0 10px rgba(0,255,136,0.05)"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "32px",
      "padding": "0 12px",
      "background": "rgba(0,255,136,0.06)"
    },
    "pre": {
      "background": "#12121a",
      "color": "#c0c0c8",
      "padding": "16px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#00ff88",
      "font_size": "13px",
      "font_family": "'Courier New', Menlo, Monaco, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "separate",
      "margin_top": "20px",
      "margin_bottom": "20px",
      "font_size": "14px",
      "border_spacing": "0",
      "border_radius": "4px",
      "overflow": "hidden",
      "border": "1px solid rgba(0,255,136,0.15)"
    },
    "th": {
      "background": "rgba(0,255,136,0.12)",
      "padding": "12px 16px",
      "text_align": "left",
      "font_weight": "600",
      "color": "#00ff88",
      "border_bottom": "1px solid rgba(0,255,136,0.2)",
      "font_size": "12px",
      "letter_spacing": "0.05em"
    },
    "td": {
      "padding": "12px 16px",
      "font_size": "14px",
      "line_height": "1.6",
      "background": "#0a0a0f",
      "color": "#c0c0c8",
      "border_bottom": "1px solid rgba(255,255,255,0.04)"
    },
    "list_item_bullet": {
      "color": "#00ff88",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "rgba(0,255,136,0.15)",
      "color": "#00ff88",
      "border_radius": "3px",
      "font_size": "12px",
      "font_weight": "600",
      "margin_right": "8px",
      "margin_top": "4px"
    },
    "list_item_text": {
      "font_size": "15px",
      "color": "#c0c0c8",
      "line_height": "1.8",
      "letter_spacing": "0.03em",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px dashed rgba(0,255,136,0.15)"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "600",
      "color": "#666677",
      "margin_bottom": "10px",
      "letter_spacing": "0.05em"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#666677",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#00ff88",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "rgba(0,255,136,0.06)",
      "border_left": "3px solid #00ff88",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "3px"
    },
    "callout_title": {
      "font_weight": "600",
      "color": "#00ff88",
      "margin_bottom": "8px",
      "font_size": "15px"
    },
    "callout_content": {
      "font_size": "14px",
      "color": "#a0a8b0",
      "line_height": "1.8",
      "letter_spacing": "0.03em",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "h4": {
      "font_size": "17px",
      "font_weight": "600",
      "color": "#00dd77",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "border_left": "2px solid rgba(0,255,136,0.3)",
      "padding_left": "8px",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "500",
      "color": "#889999",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "400",
      "color": "#667777",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "'Orbitron', -apple-system, BlinkMacSystemFont, sans-serif"
    }
  }
}