{
  "name": "社论·报",
  "description": "严肃社论 #1a1a1a + 衬线标题，传统报纸专栏风格，适合深度评论、时事分析、专业论述",
  "colors": {
    "primary": "#1a1a1a",
    "accent": "#8b0000",
    "background": "#fefefe",
    "blockquote_bg": "#f9f7f4",
    "code_bg": "#f5f5f0",
    "hr_color": "#8b0000",
    "footnote_bg": "#fefefe"
  },
  "styles": {
    "wrapper": {
      "background_color": "#fefefe",
      "padding": "16px"
    },
    "h1": {
      "font_size": "30px",
      "font_weight": "900",
      "color": "#1a1a1a",
      "line_height": "1.2",
      "margin_top": "0",
      "margin_bottom": "24px",
      "text_align": "center",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, 'Times New Roman', serif",
      "padding": "20px 0",
      "border_top": "4px double #1a1a1a",
      "border_bottom": "1px solid #1a1a1a"
    },
    "h2": {
      "font_size": "22px",
      "font_weight": "700",
      "color": "#1a1a1a",
      "line_height": "1.35",
      "margin_top": "32px",
      "margin_bottom": "14px",
      "text_align": "center",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif",
      "letter_spacing": "0.03em",
      "padding": "0"
    },
    "h3": {
      "font_size": "19px",
      "font_weight": "700",
      "color": "#333333",
      "line_height": "1.4",
      "margin_top": "24px",
      "margin_bottom": "12px",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif",
      "text_align": "center",
      "padding": "0"
    },
    "p": {
      "font_size": "16px",
      "color": "#222222",
      "line_height": "1.9",
      "margin_top": "0",
      "margin_bottom": "20px",
      "letter_spacing": "0.01em",
      "text_align": "justify",
      "text_indent": "2em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "blockquote": {
      "border_left": "3px solid #8b0000",
      "background": "#f9f7f4",
      "padding": "18px 24px",
      "border_radius": "0",
      "margin_top": "18px",
      "margin_bottom": "24px",
      "font_size": "16px",
      "color": "#444444",
      "line_height": "1.85",
      "font_family": "Georgia, serif",
      "text_align": "justify"
    },
    "blockquote_p": {
      "font_size": "16px",
      "color": "#444444",
      "line_height": "1.85",
      "margin_bottom": "0",
      "text_align": "justify",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "strong": {
      "font_weight": "700",
      "color": "#1a1a1a"
    },
    "em": {
      "font_style": "italic",
      "color": "#555555"
    },
    "a": {
      "color": "#8b0000",
      "text_decoration": "underline"
    },
    "img": {
      "max_width": "100%",
      "border_radius": "0",
      "display": "block"
    },
    "img_wrapper": {
      "background": "#fefefe",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "18px"
    },
    "hr": {
      "margin_top": "36px",
      "margin_bottom": "36px",
      "height": "1px",
      "background": "#1a1a1a",
      "border": "none",
      "width": "100%"
    },
    "code": {
      "background": "#f5f5f0",
      "padding": "2px 6px",
      "border_radius": "2px",
      "font_size": "90%",
      "color": "#444444",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "code_block": {
      "background": "#f5f5f0",
      "border_radius": "0",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "overflow": "hidden",
      "border": "1px solid #d5d5cc"
    },
    "code_header": {
      "display": "flex",
      "align_items": "center",
      "height": "30px",
      "padding": "0 12px",
      "background": "#e5e5dc"
    },
    "pre": {
      "background": "#f5f5f0",
      "color": "#222222",
      "padding": "14px",
      "border_radius": "0",
      "overflow_x": "auto",
      "margin_top": "0",
      "margin_bottom": "0",
      "font_size": "13px",
      "line_height": "1.5",
      "white_space": "pre-wrap",
      "word_wrap": "break-word",
      "word_break": "break-all"
    },
    "pre_code": {
      "background": "none",
      "padding": "0",
      "color": "#222222",
      "font_size": "13px",
      "font_family": "Menlo, Monaco, Consolas, monospace"
    },
    "table": {
      "width": "100%",
      "border_collapse": "collapse",
      "margin_top": "18px",
      "margin_bottom": "18px",
      "font_size": "14px",
      "border": "1px solid #1a1a1a"
    },
    "th": {
      "background": "#1a1a1a",
      "padding": "10px 14px",
      "text_align": "left",
      "font_weight": "700",
      "color": "#ffffff",
      "border": "1px solid #1a1a1a",
      "font_size": "12px",
      "letter_spacing": "0.04em",
      "font_family": "Georgia, serif"
    },
    "td": {
      "padding": "10px 14px",
      "font_size": "13px",
      "line_height": "1.65",
      "background": "#ffffff",
      "color": "#222222",
      "border": "1px solid #999999"
    },
    "list_item_bullet": {
      "color": "#8b0000",
      "margin_right": "8px",
      "font_weight": "bold"
    },
    "ol_item_bullet": {
      "display": "inline-flex",
      "align_items": "center",
      "justify_content": "center",
      "width": "22px",
      "height": "22px",
      "min_width": "22px",
      "background": "#1a1a1a",
      "color": "#ffffff",
      "border_radius": "0",
      "font_size": "12px",
      "font_weight": "700",
      "margin_right": "8px",
      "margin_top": "4px",
      "font_family": "Georgia, serif"
    },
    "list_item_text": {
      "font_size": "16px",
      "color": "#222222",
      "line_height": "1.9",
      "letter_spacing": "0.01em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "list_wrapper": {
      "margin_top": "16px",
      "margin_bottom": "16px"
    },
    "list_item_row": {
      "display": "flex",
      "margin_bottom": "6px",
      "align_items": "flex-start"
    },
    "footnote_section": {
      "margin_top": "32px",
      "padding_top": "16px",
      "border_top": "1px solid #1a1a1a"
    },
    "footnote_title": {
      "font_size": "12px",
      "font_weight": "700",
      "color": "#666666",
      "margin_bottom": "10px",
      "letter_spacing": "0.05em",
      "font_family": "Georgia, serif"
    },
    "footnote_item": {
      "font_size": "11px",
      "color": "#666666",
      "margin_bottom": "5px",
      "line_height": "1.6",
      "word_break": "break-all",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "footnote_sup": {
      "font_size": "10px",
      "color": "#8b0000",
      "vertical_align": "super",
      "margin_left": "2px"
    },
    "callout": {
      "background": "#f9f7f4",
      "border": "1px solid #1a1a1a",
      "border_left": "3px solid #8b0000",
      "padding": "16px 20px",
      "margin_top": "16px",
      "margin_bottom": "16px",
      "border_radius": "0"
    },
    "callout_title": {
      "font_weight": "700",
      "color": "#1a1a1a",
      "margin_bottom": "8px",
      "font_size": "16px",
      "font_family": "Georgia, serif"
    },
    "callout_content": {
      "font_size": "15px",
      "color": "#444444",
      "line_height": "1.85",
      "letter_spacing": "0.01em",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h4": {
      "font_size": "18px",
      "font_weight": "700",
      "color": "#1a1a1a",
      "padding": "0",
      "margin_top": "22px",
      "margin_bottom": "8px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h5": {
      "font_size": "16px",
      "font_weight": "600",
      "color": "#444444",
      "padding": "0",
      "margin_top": "18px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    },
    "h6": {
      "font_size": "14px",
      "font_weight": "500",
      "color": "#666666",
      "padding": "0",
      "margin_top": "14px",
      "margin_bottom": "6px",
      "line_height": "1.4",
      "font_family": "Georgia, 'Times New Roman', 'Noto Serif SC', serif"
    }
  }
}